<div>
    <div class="d-flex justify-content-between align-items-center">
        <h4 class="mb-4"><b>All Swap Requests</b></h4>
        <form method="GET" action="/admin/reports/swaps">
            <button class="btn btn-outline-primary-subtle" data-bs-toggle="tooltip" data-bs-placement="bottom" data-bs-title="Download Swaps Report"><i class="fa-solid fa-download"></i></button>
        </form>
        
    </div>
    <div class="table-responsive wrapTable">
        <table class="table table-bordered border-secondary-subtle table-sm ">
            <thead>
                <tr>
                <th scope="col" class="p-2">ID</th>
                <th scope="col" class="p-2 ">Sender</th>
                <th scope="col" class="p-2 "> Receiver</th>
                <th scope="col" class="p-2">Offered Skill</th>
                <th scope="col" class="p-2">Requested Skill</th>
                <th scope="col" class="p-2">Status</th>
                <th scope="col" class="p-2">Date</th>
                <th scope="col" class="p-2">Action</th>
                </tr>
            </thead>
            <tbody>
                <% swaps.forEach((swap , i) => { %>
                    <tr>
                        <td><%= i + 1 %></td>
                        <td class="p-2 table-img"><img src="<%= swap.sender.profilePhoto.url %>"> <%= swap.sender.username %></td>
                        <td class="p-2 table-img"><img src="<%= swap.receiver.profilePhoto.url %>"><%= swap.receiver.username %></td>
                        <td class="p-2"><%= swap.offeredSkill %></td>
                        <td class="p-2"><%= swap.requestedSkill %></td>
                        <td class="p-2">
                            <% if (swap.status === "pending"){ %>
                                <span class="badge text-bg-secondary">Pending</span>
                            <% } %>
                            <% if (swap.status === "accepted"){ %>
                                <span class="badge text-bg-success">Accepted</span>
                            <% } %>
                            <% if (swap.status === "rejected"){ %>
                                <span class="badge text-bg-danger">Rejected</span>
                            <% } %>
                            <% if (swap.status === "completed"){ %>
                                <span class="badge text-bg-warning">Completed</span>
                            <% } %>
                        </td>
                        <td class="p-2"><%= swap.createdAt.toLocaleDateString() %></td>
                        <!--Button Trigger Modal-->
                        <td class="p-2"><button class="btn btn-outline feedback-button btn-sm" data-bs-toggle="modal" data-bs-target="#viewDetailModal-<%= swap._id %>"><b>View Details</b></button>
                        <!-- Modal -->
                        <div class="modal fade" id="viewDetailModal-<%= swap._id %>" tabindex="-1" aria-labelledby="viewDetailModalLabel-<%= swap._id %>" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content">
                            <div class="modal-header">
                                <h1 class="modal-title fs-5" id="viewDetailModalLabel-<%= swap._id %>"><b>Swap Details</b></h1>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body">
                                <div class="row">
                                    <div class="col-5 d-flex">
                                        <div class="table-img">
                                            <img src="<%= swap.sender.profilePhoto.url %>">
                                        </div>
                                        <div>
                                            <h5><b><%= swap.sender.username %></b></h5>
                                            <h6>Sender</h6>
                                        </div>
                                    </div>
                                    <div class="col-2">
                                        <div>
                                            <i class="fa-solid fa-arrow-right-arrow-left fa-2x"></i>
                                        </div>
                                    </div>
                                    <div class="col-5 d-flex">
                                        <div class="table-img">
                                            <img src="<%= swap.receiver.profilePhoto.url %>">
                                        </div>
                                        <div>
                                            <h5><b><%= swap.receiver.username %></b></h5>
                                            <h6>Receiver</h6>
                                        </div>
                                    </div>
                                </div>
                                <div class="table-responsive">
                                    <table class="table">
                                        <tbody>
                                            <tr>
                                                <td>Offered Skill :</td>
                                                <td><%= swap.offeredSkill %></td>
                                            </tr>
                                            <tr>
                                                <td>Requested Skill :</td>
                                                <td><%= swap.requestedSkill %></td>
                                            </tr>
                                            <tr>
                                                <td>Message :</td>
                                                <td class="message-cell"><%= swap.message %></td>
                                            </tr>
                                            <tr>
                                                <td>Status :</td>
                                                <td>
                                                    <% if (swap.status === "pending"){ %>
                                                        <span class="badge text-bg-secondary">Pending</span>
                                                    <% } %>
                                                    <% if (swap.status === "accepted"){ %>
                                                        <span class="badge text-bg-success">Accepted</span>
                                                    <% } %>
                                                    <% if (swap.status === "rejected"){ %>
                                                        <span class="badge text-bg-danger">Rejected</span>
                                                    <% } %>
                                                    <% if (swap.status === "completed"){ %>
                                                        <span class="badge text-bg-warning">Completed</span>
                                                    <% } %>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td>Requested On :</td>
                                                <td><%= swap.createdAt.toLocaleDateString() %></td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                            </div>
                            </div>
                        </div>
                        </div>
                        </td>
                    </tr>
                <% }) %>
                    
                
            </tbody>
        </table>
    </div>
</div>